generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// AUTHENTICATION & USER MANAGEMENT MODELS
// ==========================================

enum Role {
  USER
  ADMIN
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  phone      String
  role       Role     @default(USER)
  created_at DateTime @default(now())

  refreshTokens RefreshToken[]
  cart          Cart?   // 1 user hanya punya 1 cart

  orders Order[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ==========================================
// PRODUCT & CATALOG MODELS
// ==========================================

enum ProductType {
  TYPE1
  TYPE2
  TYPE3
}

enum Shape {
  ROUND
  SQUARE
}

model Product {
  id          String      @id @default(uuid())
  type        ProductType

  // field umum, wajib semua tipe
  name        String
  description String
  image       String

  // hanya wajib untuk TYPE1 & TYPE2, null untuk TYPE3 (validasi di app layer)
  flavor      String?

  // diskon, opsional, default 0
  discount    Decimal     @default(0) @db.Decimal(5, 2)

  // relasi ke variant (shape + size + price)
  // TYPE1  -> hanya 1 row variant
  // TYPE2  -> banyak row, shape ROUND & SQUARE harus ada
  // TYPE3  -> sama seperti TYPE2 tapi tanpa flavor
  variants    ProductVariant[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("products")

  cartItems CartItem[]

  orderItems OrderItem[]
}

model ProductVariant {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  shape     Shape
  // diameter (cm) untuk ROUND, panjang sisi (cm) untuk SQUARE
  // contoh: 16,18,20,...,30 (kelipatan 2)
  size      Int

  price     Decimal  @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, shape, size]) // cegah duplikat size yg sama untuk 1 product+shape
  @@map("product_variants")

  cartItems CartItem[]

  orderItems OrderItem[]
}

// ==========================================
// CART
// ==========================================

model Cart {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id          String   @id @default(uuid())

  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE2 & TYPE3 (user memilih shape + size lewat variant)
  // TYPE1 tidak perlu, karena variant-nya cuma 1 row
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE3 (user memilih flavor sendiri di cart,
  // beda dengan Product.flavor yg fixed untuk TYPE1 & TYPE2)
  flavor      String?

  // hanya diisi untuk TYPE3 (upload gambar custom dari user)
  customImage String?

  // opsional untuk semua tipe
  textOnCake  String?
  notes       String?

  quantity    Int      @default(1)

  // snapshot harga per-unit pas item ditambahkan ke cart
  // (jaga2 kalau harga product/variant berubah belakangan, harga di cart ttp konsisten)
  price       Decimal  @db.Decimal(12, 2)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum DeliveryRecipientType {
  FOR_MYSELF
  FOR_SOMEONE_ELSE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Order {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     OrderItem[]

  fulfillmentType FulfillmentType

  // ===== PICKUP =====
  // hanya diisi kalau fulfillmentType = PICKUP
  requestCakeDate DateTime // tanggal ambil kue / kirim, minimal H+7 (validasi di app layer)

  // ===== DELIVERY =====
  // hanya diisi kalau fulfillmentType = DELIVERY
  recipientType   DeliveryRecipientType?

  // diisi kalau recipientType = FOR_SOMEONE_ELSE
  recipientName   String?
  recipientPhone  String?

  // alamat tujuan delivery (dipakai baik FOR_MYSELF maupun FOR_SOMEONE_ELSE)
  // untuk FOR_MYSELF, ini alamat user sendiri yang dipilih lewat map
  // untuk FOR_SOMEONE_ELSE, ini alamat penerima yang dipilih lewat map
  address         String?
  addressLat      Decimal? @db.Decimal(10, 7)
  addressLng      Decimal? @db.Decimal(10, 7)

  // jarak hasil hitung dari toko ke alamat tujuan (km), dipakai untuk hitung deliveryFee
  distanceKm      Decimal? @db.Decimal(6, 2)

  // ===== PRICING SNAPSHOT =====
  // snapshot supaya histori order tidak berubah meski harga produk/ongkir berubah di kemudian hari
  subtotal        Decimal  @db.Decimal(12, 2)
  deliveryFee     Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)

  status          OrderStatus @default(PENDING)

  // pesan WhatsApp yang dikirim ke owner, disimpan untuk audit/histori
  whatsappMessage String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE2 & TYPE3 (sama seperti CartItem)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE3
  flavor      String?
  customImage String?

  textOnCake  String?
  notes       String?

  quantity    Int

  // snapshot harga per-unit & nama produk pas order dibuat,
  // supaya histori order tidak ikut berubah kalau admin update produk nanti
  productName String
  price       Decimal  @db.Decimal(12, 2)

  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model Gallery {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  description String?
  tags        String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("galleries")
}

model VisitorLog {
  id        String   @id @default(uuid())
  visitorId String   // dari cookie, bukan userId (karena belum tentu login)
  date      DateTime @db.Date // hanya tanggal, jam diabaikan untuk dedupe harian
  userId    String?  // optional, kalau ternyata visitor itu sedang login
  createdAt DateTime @default(now())

  @@unique([visitorId, date]) // inti dedupe: 1 visitor cuma 1 row per hari
  @@index([date])
  @@map("visitor_logs")
}