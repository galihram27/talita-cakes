generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  password        String
  phone           String
  role            Role           @default(USER)
  created_at      DateTime       @default(now())
  isVerified      Boolean        @default(false)
  termsAcceptedAt DateTime?
  termsVersion    String?
  otpCodes        OtpCode[]
  refreshTokens   RefreshToken[]
  cart            Cart?
  orders          Order[]

  @@map("users")
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model OtpCode {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  attempts  Int        @default(0)
  createdAt DateTime   @default(now())

  @@index([userId, purpose])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

enum ProductType {
  TYPE1
  TYPE2
  TYPE3
  TYPE4
  TYPE5
  TYPE6
}

enum Shape {
  ROUND
  SQUARE
}

model Product {
  id            String           @id @default(uuid())
  type          ProductType
  name          String
  description   String
  descriptionEn String           @default("")
  image         String
  images        String[]         @default([])
  category      String?
  // sub-kategori level kedua, hanya dipakai TYPE5 (non-cake): mis. category
  // "Bread" -> subcategory "CINROLLS VAN DEPOK". null untuk TYPE1–TYPE4.
  subcategory   String?
  flavor        String?
  discount      Decimal          @default(0) @db.Decimal(5, 2)
  // true = dipajang di section "Our Cake Samples" pada halaman Home.
  // Admin menandai/melepas flag ini lewat panel produk.
  featured      Boolean          @default(false)
  // Konfigurasi pilihan "Filling" (hanya sub-kategori CINROLLS VAN DEPOK).
  // Pilih SATU (radio). Harga TIDAK di sini — ada di comboPrices per kombinasi.
  // Bentuk: { options: [{ name }], defaultIndex }. null = tanpa filling.
  filling       Json?
  // Konfigurasi pilihan "Topping" (hanya CINROLLS VAN DEPOK). Wajib pilih
  // minimal 1, boleh beberapa (batas maxSelect 1-3 diatur admin).
  // Bentuk: { options: [{ name }], maxSelect }. null = tanpa topping.
  topping       Json?
  // Harga TAMBAHAN per kombinasi (filling + topping), diisi admin manual.
  // Total = harga dasar + Σ harga kombinasi (filling terpilih × tiap topping terpilih).
  // Bentuk: [{ filling, topping, price }]. null = tanpa penyesuaian harga.
  comboPrices   Json?
  variants      ProductVariant[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@map("products")
}

model ProductVariant {
  id         String      @id @default(uuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  // shape & size null untuk produk lama; TYPE5 (non-cake) kini pakai shape+size.
  shape      Shape?
  size       Int?
  // dimensi kedua untuk shape SQUARE (mis. 20x10 -> size=20, sizeB=10).
  // null untuk ROUND & untuk cake (square cake tetap NxN memakai size saja).
  sizeB      Int?
  price      Decimal     @db.Decimal(12, 2)
  // foto yang mewakili varian ini, dipilih dari Product.images.
  // Dipakai TYPE6: memilih isi box menggeser galeri ke foto box tsb.
  // null = varian tidak punya foto khusus, galeri dibiarkan apa adanya.
  image      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, shape, size])
  @@map("product_variants")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id          String          @id @default(uuid())
  cartId      String
  cart        Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  flavor      String?
  // pilihan filling user (satu nama). null = produk tanpa filling.
  // Hanya dipakai CINROLLS VAN DEPOK (TYPE5).
  filling     String?
  // pilihan topping user (nama tergabung, mis. "Almond, Keju"). null = tanpa topping.
  topping     String?
  customImage String?
  textOnCake  String?
  notes       String?
  quantity    Int             @default(1)
  price       Decimal         @db.Decimal(12, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum DeliveryRecipientType {
  FOR_MYSELF
  FOR_SOMEONE_ELSE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Order {
  id                   String                 @id @default(uuid())
  userId               String
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                OrderItem[]
  fulfillmentType      FulfillmentType
  requestCakeDate      DateTime
  recipientType        DeliveryRecipientType?
  recipientName        String?
  recipientPhone       String?
  recipientDataConsent Boolean                @default(false)
  address              String?
  addressLat           Decimal?               @db.Decimal(10, 7)
  addressLng           Decimal?               @db.Decimal(10, 7)
  distanceKm           Decimal?               @db.Decimal(6, 2)
  subtotal             Decimal                @db.Decimal(12, 2)
  deliveryFee          Decimal                @default(0) @db.Decimal(12, 2)
  total                Decimal                @db.Decimal(12, 2)
  status               OrderStatus            @default(PENDING)
  whatsappMessage      String?                @db.Text
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id          String          @id @default(uuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  flavor      String?
  // snapshot pilihan filling user (satu nama). null = tanpa filling.
  filling     String?
  // snapshot pilihan topping user (nama tergabung). null = tanpa topping.
  topping     String?
  customImage String?
  textOnCake  String?
  notes       String?
  quantity    Int
  productName String
  price       Decimal         @db.Decimal(12, 2)
  createdAt   DateTime        @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model Gallery {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  description String?
  tags        String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("galleries")
}

model VisitorLog {
  id        String   @id @default(uuid())
  visitorId String
  date      DateTime @db.Date
  userId    String?
  createdAt DateTime @default(now())

  @@unique([visitorId, date])
  @@index([date])
  @@map("visitor_logs")
}
