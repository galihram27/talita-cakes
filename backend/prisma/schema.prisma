generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// AUTHENTICATION & USER MANAGEMENT MODELS
// ==========================================

enum Role {
  USER
  ADMIN
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  phone      String
  role       Role     @default(USER)
  created_at DateTime @default(now())

  isVerified Boolean  @default(false)

  // ===== TERMS & PRIVACY CONSENT =====
  // Disimpan buat bukti audit: kapan user setuju & versi dokumen yang mana.
  // termsVersion berguna kalau nanti Terms of Use di-update, sehingga
  // kamu bisa tahu user mana yang belum agree ke versi terbaru.
  termsAcceptedAt DateTime?
  termsVersion    String?

  otpCodes   OtpCode[]
  refreshTokens RefreshToken[]
  cart          Cart?   // 1 user hanya punya 1 cart

  orders Order[]

  @@map("users")
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model OtpCode {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String     // hashed pakai bcrypt, bukan plaintext
  purpose   OtpPurpose
  expiresAt DateTime
  attempts  Int        @default(0)
  createdAt DateTime   @default(now())

  @@index([userId, purpose])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ==========================================
// PRODUCT & CATALOG MODELS
// ==========================================

enum ProductType {
  TYPE1 // fixed: shape, size, dan flavor sudah ditentukan
  TYPE2 // shape & size fixed (1 variant), user pilih flavor + dekorasi
  TYPE3 // flavor fixed, user pilih shape & size (variants)
  TYPE4 // user pilih shape & size (variants) + flavor + dekorasi
}

enum Shape {
  ROUND
  SQUARE
}

model Product {
  id          String      @id @default(uuid())
  type        ProductType

  // field umum, wajib semua tipe
  name        String
  description String

  // image = foto utama / cover (dipakai di listing, card, keranjang).
  // Selalu di-sync dari images[0] di app layer, jadi tetap kompatibel
  // dengan konsumen lama yang masih membaca `image`.
  image       String

  // images = semua foto produk (galeri). Elemen pertama = cover.
  // Satu produk bisa punya banyak foto lewat kolom ini.
  images      String[]    @default([])

  // kategori per type, daftar valid ada di product.constant.js (PRODUCT_CATEGORIES)
  // nullable di DB supaya aman untuk data lama, tapi wajib diisi via validasi app layer
  category    String?

  // flavor fixed, hanya wajib untuk TYPE1 & TYPE3,
  // null untuk TYPE2 & TYPE4 karena user pilih sendiri (validasi di app layer)
  flavor      String?

  // diskon, opsional, default 0
  discount    Decimal     @default(0) @db.Decimal(5, 2)

  // relasi ke variant (shape + size + price)
  // TYPE1 & TYPE2 -> hanya 1 row variant (fixed)
  // TYPE3 & TYPE4 -> banyak row, shape ROUND & SQUARE harus ada
  variants    ProductVariant[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("products")

  cartItems CartItem[]

  orderItems OrderItem[]
}

model ProductVariant {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  shape     Shape
  // diameter (cm) untuk ROUND, panjang sisi (cm) untuk SQUARE
  // contoh: 16,18,20,...,30 (kelipatan 2)
  size      Int

  price     Decimal  @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, shape, size]) // cegah duplikat size yg sama untuk 1 product+shape
  @@map("product_variants")

  cartItems CartItem[]

  orderItems OrderItem[]
}

// ==========================================
// CART
// ==========================================

model Cart {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id          String   @id @default(uuid())

  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE3 & TYPE4 (user memilih shape + size lewat variant)
  // TYPE1 & TYPE2 tidak perlu, karena variant-nya cuma 1 row
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE2 & TYPE4 (user memilih flavor sendiri di cart,
  // beda dengan Product.flavor yg fixed untuk TYPE1 & TYPE3)
  flavor      String?

  // hanya diisi untuk TYPE2 & TYPE4 (upload gambar dekorasi custom dari user)
  customImage String?

  // opsional untuk semua tipe
  textOnCake  String?
  notes       String?

  quantity    Int      @default(1)

  // snapshot harga per-unit pas item ditambahkan ke cart
  // (jaga2 kalau harga product/variant berubah belakangan, harga di cart ttp konsisten)
  price       Decimal  @db.Decimal(12, 2)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum DeliveryRecipientType {
  FOR_MYSELF
  FOR_SOMEONE_ELSE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Order {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     OrderItem[]

  fulfillmentType FulfillmentType

  // ===== PICKUP =====
  // hanya diisi kalau fulfillmentType = PICKUP
  requestCakeDate DateTime // tanggal ambil kue / kirim, minimal H+7 (validasi di app layer)

  // ===== DELIVERY =====
  // hanya diisi kalau fulfillmentType = DELIVERY
  recipientType   DeliveryRecipientType?

  // diisi kalau recipientType = FOR_SOMEONE_ELSE
  recipientName   String?
  recipientPhone  String?
  // hanya diisi kalau recipientType = FOR_SOMEONE_ELSE
  // bukti bahwa user menyatakan sudah dapat izin dari penerima
  // untuk membagikan nama, no HP, dan alamatnya demi keperluan pengiriman
  recipientDataConsent Boolean @default(false)

  // alamat tujuan delivery (dipakai baik FOR_MYSELF maupun FOR_SOMEONE_ELSE)
  // untuk FOR_MYSELF, ini alamat user sendiri yang dipilih lewat map
  // untuk FOR_SOMEONE_ELSE, ini alamat penerima yang dipilih lewat map
  address         String?
  addressLat      Decimal? @db.Decimal(10, 7)
  addressLng      Decimal? @db.Decimal(10, 7)

  // jarak hasil hitung dari toko ke alamat tujuan (km), dipakai untuk hitung deliveryFee
  distanceKm      Decimal? @db.Decimal(6, 2)

  // ===== PRICING SNAPSHOT =====
  // snapshot supaya histori order tidak berubah meski harga produk/ongkir berubah di kemudian hari
  subtotal        Decimal  @db.Decimal(12, 2)
  deliveryFee     Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)

  status          OrderStatus @default(PENDING)

  // pesan WhatsApp yang dikirim ke owner, disimpan untuk audit/histori
  whatsappMessage String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE3 & TYPE4 (sama seperti CartItem)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // hanya diisi untuk TYPE2 & TYPE4
  flavor      String?
  customImage String?

  textOnCake  String?
  notes       String?

  quantity    Int

  // snapshot harga per-unit & nama produk pas order dibuat,
  // supaya histori order tidak ikut berubah kalau admin update produk nanti
  productName String
  price       Decimal  @db.Decimal(12, 2)

  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model Gallery {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  description String?
  tags        String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("galleries")
}

model VisitorLog {
  id        String   @id @default(uuid())
  visitorId String   // dari cookie, bukan userId (karena belum tentu login)
  date      DateTime @db.Date // hanya tanggal, jam diabaikan untuk dedupe harian
  userId    String?  // optional, kalau ternyata visitor itu sedang login
  createdAt DateTime @default(now())

  @@unique([visitorId, date]) // inti dedupe: 1 visitor cuma 1 row per hari
  @@index([date])
  @@map("visitor_logs")
}