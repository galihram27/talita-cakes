# ===== Database (Neon) =====
# Gunakan connection string POOLED (yang ada "-pooler") untuk aplikasi.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# ===== Runtime =====
# Set "production" di Render. Jangan diisi saat development lokal.
NODE_ENV=production
# PORT tidak perlu diisi di Render (di-set otomatis). Default lokal: 5000.
# PORT=5000

# URL frontend (Vercel) untuk CORS + cookie lintas domain.
FRONTEND_URL="https://nama-app.vercel.app"

# ===== Auth / JWT =====
JWT_SECRET="isi-random-panjang"
JWT_REFRESH_SECRET="isi-random-panjang-berbeda"

# ===== Cloudinary (upload gambar) =====
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ===== Email (Resend) =====
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Talita Cakes <no-reply@domainmu.com>"

# ===== Info toko / lokasi (ongkir & maps) =====
OWNER_WHATSAPP_NUMBER="6281234567890"
STORE_LATITUDE=""
STORE_LONGITUDE=""
GOOGLE_MAPS_API_KEY=""
GOOGLE_PLACE_ID=""

# OpenRouteService API key (gratis, tanpa kartu) untuk hitung jarak rute
# ongkir. Daftar di https://openrouteservice.org/dev/#/home
ORS_API_KEY=""

# ===== Auto-rebuild situs statis (SSG/SEO) =====
# Build/Deploy Hook dari host frontend (Netlify/Vercel/Cloudflare/Render).
# Kalau di-set, backend memicu rebuild otomatis saat produk/gallery berubah,
# supaya halaman prerender ikut ter-update untuk SEO. Kosong = fitur mati.
DEPLOY_HOOK_URL=""
# Jeda debounce (ms) — banyak perubahan beruntun hanya memicu 1 build. Default 120000 (2 mnt).
DEPLOY_HOOK_DEBOUNCE_MS=""
